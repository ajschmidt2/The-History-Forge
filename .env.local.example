# --- Ollama (local default provider: metadata, cleanup, tags, JSON extraction, embeddings) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TEXT_MODEL=qwen3.5:9b
OLLAMA_JSON_MODEL=qwen3.5:9b
OLLAMA_EMBED_MODEL=embeddinggemma
# Setup: ollama serve && ollama pull qwen3.5:9b && ollama pull embeddinggemma

# --- OpenAI (premium writing, narration, TTS) ---
OPENAI_API_KEY=sk-proj-...
OPENAI_TEXT_MODEL=gpt-4o
OPENAI_FAST_MODEL=gpt-4o-mini
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy
# Legacy key still supported: OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=AIza...
GEMINI_MODEL_TEXT=gemini-2.5-flash
GEMINI_MODEL_FAST=gemini-2.5-flash
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
GEMINI_VIDEO_MODEL=veo-3.1-lite-generate-preview

# Trend Intelligence
YOUTUBE_API_KEY=your_youtube_data_api_key
GOOGLE_TRENDS_GEO=US
